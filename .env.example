# Copy this file to .env and fill in your own keys
# Never commit .env to GitHub

GEMINI_API_KEY=your-gemini-api-key-here

# --- COMPRESSION SETTINGS ---
CODECARBON_ENABLED=true  # Set to false on Windows if hardware detection times out
COMPRESSION_THRESHOLD=500
# https://aistudio.google.com/app/apikey

# Optional: other LLM providers
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# HuggingFace token for IndicTrans2 translation (better quality)
# Get free token at: https://huggingface.co/settings/tokens
# Without this, translation falls back to Google Translate automatically
HUGGINGFACE_TOKEN=your_hf_token_here
